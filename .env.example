# ─────────────────────────────────────────────────────────────
# BONS ENGINE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub (it's in .gitignore).
# ─────────────────────────────────────────────────────────────

# ── ANTHROPIC (Script generation) ────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── HEYGEN (AI avatar videos) ────────────────────────────────
# Get from: app.heygen.com → Account → API
HEYGEN_API_KEY=your_heygen_api_key_here
# Browse avatars at: app.heygen.com → Avatars
# Click an avatar → ID appears in the URL or avatar details panel
HEYGEN_AVATAR_ID=your_chosen_heygen_avatar_id_here

# ── ELEVENLABS (AI voice inside HeyGen) ──────────────────────
# Get from: elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Browse voices at: elevenlabs.io → Voice Library
# Click a voice → ID appears in the URL
ELEVENLABS_VOICE_ID=your_chosen_voice_id_here

# ── PUBLER (Social scheduling) ───────────────────────────────
# Get from: app.publer.com → Settings → Integrations → API
PUBLER_API_KEY=b01cd59c482d64c70976eb8d1d90104e8239dab0764e9ade

# Run: node scripts/get-publer-ids.js to find your profile IDs
PUBLER_TIKTOK_ID=your_publer_tiktok_profile_id
PUBLER_INSTAGRAM_ID=your_publer_instagram_profile_id
PUBLER_PINTEREST_ID=your_publer_pinterest_profile_id

# ── GOOGLE (Waitlist — already configured on Render) ─────────
# These are used by waitlist-server.js on Render.com
# They live in Render's Secret Files, not here.
# (No action needed — waitlist is already working)
